<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Resumen warning de la venta anterior. -->
    <t t-name="pos_conventional_payment_wizard.CashChangeBanner">
        <div t-if="visible"
             class="pos-previous-sale-banner alert alert-warning d-flex align-items-start justify-content-between mb-3 shadow-sm"
             role="alert">

            <div class="d-flex align-items-start gap-3">
                <i class="fa fa-exclamation-triangle mt-1" style="font-size: 1.5rem; opacity: 0.9;"/>
                <div>
                    <div class="fw-bold text-uppercase small" style="letter-spacing: 0.08em;">
                        Resumen de la venta anterior
                    </div>
                    <div class="mt-1">
                        <span t-if="formattedTotal" class="me-4">
                            <strong>Total:</strong>&#160;
                            <t t-esc="formattedTotal"/>&#160;<t t-esc="state.currencySymbol"/>
                        </span>
                        <span>
                            <strong>Cambio:</strong>&#160;
                            <t t-esc="formattedChange"/>&#160;<t t-esc="state.currencySymbol"/>
                        </span>
                    </div>
                </div>
            </div>

            <button class="btn btn-link text-reset p-0 ms-3"
                    title="Descartar (también desaparece al añadir una línea)"
                    t-on-click="onDismiss">
                <i class="fa fa-times-circle" style="font-size: 1.35rem; opacity: 0.75;"/>
            </button>
        </div>
    </t>

</templates>


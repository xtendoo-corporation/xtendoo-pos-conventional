<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Resumen warning de la venta anterior. -->
    <t t-name="pos_conventional_payment_wizard.CashChangeBanner">
        <div t-if="visible"
             class="pos-previous-sale-banner alert alert-warning d-flex align-items-center justify-content-between mb-3 shadow-sm py-2 px-3"
             role="alert">

            <div class="d-flex align-items-center gap-3">
                <i class="fa fa-exclamation-triangle fs-4 text-warning" style="opacity: 0.9;"/>
                <div class="d-flex align-items-center gap-4">
                    <span t-if="formattedTotal" class="d-flex align-items-center">
                        <strong class="text-uppercase small me-1">Total anterior:</strong>
                        <span class="fs-5 fw-semibold"><t t-esc="formattedTotal"/>&#160;<t t-esc="state.currencySymbol"/></span>
                    </span>
                    <span class="d-flex align-items-center">
                        <strong class="text-uppercase small me-1">Cambio anterior:</strong>
                        <span class="fs-5 fw-semibold"><t t-esc="formattedChange"/>&#160;<t t-esc="state.currencySymbol"/></span>
                    </span>
                </div>
            </div>

            <button class="btn btn-link text-reset p-0 ms-3"
                    title="Descartar (también desaparece al añadir una línea)"
                    t-on-click="onDismiss">
                <i class="fa fa-times-circle" style="font-size: 1.35rem; opacity: 0.75;"/>
            </button>
        </div>
    </t>

</templates>

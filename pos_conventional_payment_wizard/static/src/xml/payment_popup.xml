<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_conventional_payment_wizard.PaymentPopup">
        <Dialog title="'Realizar Pago'" size="'xl'" contentClass="'payment-popup-dialog'">
            <div class="d-flex flex-column bg-light">
                <t t-if="state.loading">
                    <div class="text-center p-5">Cargando...</div>
                </t>
                <t t-else="">
                    <!-- Cabecera: métodos de pago + total pendiente -->
                    <div class="d-flex justify-content-between align-items-start p-4 bg-white border-bottom">
                        <div class="d-flex flex-column gap-3 flex-grow-1">
                            <t t-foreach="state.orderData.available_methods" t-as="method" t-key="method.id">
                                <button class="btn btn-outline-secondary text-start fw-bold p-3"
                                        t-on-click="() => this.addPayment(method.id)">
                                    <i t-attf-class="fa {{method.icon}} me-2"/>
                                    <t t-esc="method.name"/>
                                </button>
                            </t>
                        </div>
                        <!-- Importe pendiente -->
                        <div class="text-end ms-4">
                            <div class="text-muted small text-uppercase mb-1">Pendiente</div>
                            <div t-attf-class="display-5 fw-bolder {{ amountDue &lt;= 0 ? 'text-success' : 'text-danger' }}">
                                <t t-esc="amountDue"/>
                                <span class="fs-3 ms-1"><t t-esc="state.orderData.currency_symbol"/></span>
                            </div>
                        </div>
                    </div>

                    <!-- Lista de pagos registrados -->
                    <div class="flex-grow-1 p-4 overflow-auto">
                        <div t-foreach="state.payments" t-as="p" t-key="p.id"
                             t-attf-class="d-flex justify-content-between align-items-center p-3 bg-white border mb-2 rounded {{ state.selectedPaymentId === p.id ? 'border-primary bg-primary bg-opacity-10' : '' }}"
                             t-on-click="() => this.selectPayment(p)">
                            <span><t t-esc="p.payment_method_name"/></span>
                            <span class="fw-bolder text-end"><t t-esc="p.amount"/></span>
                        </div>
                    </div>

                    <!-- Pie: cancelar / validar -->
                    <div class="d-flex justify-content-between align-items-center p-4 bg-white border-top">
                        <button class="btn btn-secondary btn-lg" t-on-click="props.close">
                            Cancelar
                        </button>
                        <button class="btn btn-success btn-lg fw-bold px-5"
                                t-att-disabled="amountDue > 0.05"
                                t-on-click="validate">
                            VALIDAR <i class="fa fa-chevron-right ms-2"/>
                        </button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

</templates>

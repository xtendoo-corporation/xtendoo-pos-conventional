<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_pos_form_payment_wizard" model="ir.ui.view">
        <field name="name">pos.order.form.payment.wizard</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(pos_conventional_payment_wizard.action_pos_conventional_payment_popup)d" 
                        string="Pagar (Avanzado)" 
                        type="action" 
                        class="oe_highlight" 
                        invisible="state != 'draft'"/>
                
                <!-- Widget para botones de pago rápido -->
                <field name="available_payment_method_ids" widget="pos_payment_buttons" invisible="state != 'draft'"/>
            </xpath>
        </field>
    </record>

    <!-- Acción de cliente para el popup de pago -->
    <record id="action_pos_conventional_payment_popup" model="ir.actions.client">
        <field name="name">Pago Avanzado</field>
        <field name="tag">pos_conventional_payment_popup</field>
        <field name="target">new</field>
    </record>
</odoo>

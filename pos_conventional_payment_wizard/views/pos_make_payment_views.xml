<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_make_payment_wizard_form" model="ir.ui.view">
        <field name="name">pos.make.payment.wizard.form</field>
        <field name="model">pos.make.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Realizar Pago">
                <sheet>
                    <field name="order_id" invisible="1" />
                    <field name="config_id" invisible="1" />
                    <field name="currency_id" invisible="1" />
                    <field name="available_payment_method_ids" invisible="1" />

                    <separator string="Registrar Pago" />

                    <group>
                        <group>
                            <field name="is_cash_payment" invisible="1" />
                            <field name="payment_method_id"
                                options="{'no_create': True, 'no_open': True}"
                                required="1" />
                            <field name="amount_tendered" />
                            <field name="amount_change"
                                invisible="not is_cash_payment"
                                readonly="1" />
                            <button name="action_add_payment" type="object" string="Añadir" />
                        </group>
                        <group string="Resumen">
                            <field name="amount_due" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                string="Total a pagar"
                                readonly="1" />
                            <field name="amount_paid" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                string="Pagado" />
                        </group>
                    </group>

                    <separator string="Pagos registrados" />

                    <field name="payment_ids" nolabel="1" mode="list">
                        <list create="0" delete="1">
                            <field name="payment_method_id" />
                            <field name="amount" sum="Total" />
                            <button name="unlink" type="object" icon="fa-trash" title="Eliminar" />
                        </list>
                    </field>

                    <separator string="Aún no hay pagos registrados para este pedido." invisible="payment_ids" />
                </sheet>
                <footer>
                    <button name="action_validate" type="object"
                        string="VALIDAR"
                        icon="fa-check"
                        invisible="amount_due &gt; 0.01" />
                    <button string="Descartar" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="view_pos_make_payment_wizard_cash_form" model="ir.ui.view">
        <field name="name">pos.make.payment.wizard.cash.form</field>
        <field name="model">pos.make.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Cobro en Efectivo">
                <sheet>
                    <field name="is_cash_payment" invisible="1" />
                    <field name="currency_id" invisible="1" />
                    <field name="order_id" invisible="1" />
                    <field name="payment_method_id" invisible="1" />

                    <group>
                        <group string="Importes">
                            <field name="amount_due" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                string="Total a pagar"
                                readonly="1" />
                            <field name="amount_tendered" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                string="Importe entregado" />
                            <field name="amount_change" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                string="Cambio a devolver"
                                readonly="1"
                                invisible="not is_cash_payment" />
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_validate" type="object"
                        string="VALIDAR Y FINALIZAR"
                        icon="fa-check-circle" />
                    <button string="Cancelar" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_make_payment_wizard" model="ir.actions.act_window">
        <field name="name">Realizar Pago</field>
        <field name="res_model">pos.make.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pos_make_payment_wizard_form" />
        <field name="target">new</field>
    </record>
</odoo>

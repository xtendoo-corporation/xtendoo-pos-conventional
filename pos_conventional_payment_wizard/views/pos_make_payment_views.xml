<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_make_payment_wizard_form" model="ir.ui.view">
        <field name="name">pos.make.payment.wizard.form</field>
        <field name="model">pos.make.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Realizar Pago">
                <sheet>
                    <field name="order_id" invisible="1" />
                    <field name="config_id" invisible="1" />
                    <field name="currency_id" invisible="1" />
                    <field name="available_payment_method_ids" invisible="1" />

                    <!-- Resumen del ticket: filas apiladas, etiqueta e importe del mismo tamaño -->
                    <div class="p-3 bg-light rounded mb-3">
                        <!-- Fila 1: Total del ticket (fijo, nunca baja) -->
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                            <span class="fs-2 fw-bold">Total a pagar</span>
                            <field name="amount_total" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                readonly="1" nolabel="1"
                                class="fs-2 fw-bold text-end"/>
                        </div>
                        <!-- Fila 2: Pagado — rojo si no cubre el total, verde si lo cubre -->
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-2 fw-bold">Pagado</span>
                            <div class="text-end">
                                <field name="amount_paid" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"
                                    readonly="1" nolabel="1"
                                    class="fs-2 fw-bold text-danger"
                                    invisible="amount_paid >= amount_total"/>
                                <field name="amount_paid" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"
                                    readonly="1" nolabel="1"
                                    class="fs-2 fw-bold text-success"
                                    invisible="amount_paid &lt; amount_total"/>
                            </div>
                        </div>
                    </div>

                    <separator string="Registrar Pago" />

                    <group>
                        <field name="is_cash_payment" invisible="1" />
                        <field name="payment_method_id"
                            options="{'no_create': True, 'no_open': True}"
                            required="1" />
                        <field name="amount_tendered" />
                        <field name="amount_change"
                            invisible="not is_cash_payment"
                            readonly="1" />
                        <button name="action_add_payment" type="object" string="Añadir" />
                    </group>

                    <separator string="Pagos registrados" />

                    <field name="payment_ids" nolabel="1" mode="list">
                        <list create="0" delete="1">
                            <field name="payment_method_id" />
                            <field name="amount" sum="Total" />
                        </list>
                    </field>

                    <separator string="Aún no hay pagos registrados para este pedido." invisible="payment_ids" />
                </sheet>
                <footer>
                    <!-- amount_due sigue controlando si queda saldo pendiente -->
                    <button name="action_validate" type="object"
                        string="Confirmar Pago"
                        icon="fa-check"
                        invisible="amount_due &gt; 0.01" />
                    <button string="Descartar" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="view_pos_make_payment_wizard_cash_form" model="ir.ui.view">
        <field name="name">pos.make.payment.wizard.cash.form</field>
        <field name="model">pos.make.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Cobro en Efectivo">
                <sheet>
                    <field name="is_cash_payment" invisible="1" />
                    <field name="currency_id" invisible="1" />
                    <field name="order_id" invisible="1" />
                    <field name="payment_method_id" invisible="1" />

                    <!-- Resumen del ticket: filas apiladas, etiqueta e importe del mismo tamaño -->
                    <div class="p-3 bg-light rounded mb-3">
                        <!-- Fila 1: Total del ticket (fijo) -->
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                            <span class="fs-2 fw-bold">Total a pagar</span>
                            <field name="amount_total" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                readonly="1" nolabel="1"
                                class="fs-2 fw-bold text-end"/>
                        </div>
                        <!-- Fila 2: Importe entregado -->
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                            <span class="fs-2 fw-bold">Importe entregado</span>
                            <field name="amount_tendered" widget="monetary"
                                options="{'currency_field': 'currency_id'}"
                                nolabel="1"
                                class="fs-2 fw-bold text-primary text-end"/>
                        </div>
                        <!-- Fila 3: Cambio a devolver — verde si positivo o cero, rojo si negativo -->
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-2 fw-bold">Cambio a devolver</span>
                            <div class="text-end">
                                <field name="amount_change" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"
                                    readonly="1" nolabel="1"
                                    class="fs-2 fw-bold text-success"
                                    invisible="amount_change &lt; 0"/>
                                <field name="amount_change" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"
                                    readonly="1" nolabel="1"
                                    class="fs-2 fw-bold text-danger"
                                    invisible="amount_change &gt;= 0"/>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button name="action_validate" type="object"
                        string="VALIDAR Y FINALIZAR"
                        icon="fa-check-circle" />
                    <button string="Cancelar" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_make_payment_wizard" model="ir.actions.act_window">
        <field name="name">Realizar Pago</field>
        <field name="res_model">pos.make.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pos_make_payment_wizard_form" />
        <field name="target">new</field>
    </record>
</odoo>

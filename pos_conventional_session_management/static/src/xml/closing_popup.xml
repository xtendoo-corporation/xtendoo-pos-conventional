<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_conventional_session_management.PaymentMethodBreakdown">
        <div class="payment-method-breakdown" t-if="props.transactions and props.transactions.length > 0">
            <div class="d-flex align-items-center justify-content-between text-muted border-start ps-2 cursor-pointer"
                 t-on-click="toggle">
                <span>
                    <i t-attf-class="fa fa-caret-{{ state.open ? 'down' : 'right' }} me-1"/>
                    <t t-esc="props.title || 'Movimientos'"/>
                </span>
                <span t-esc="formatCurrency(props.total_amount)"/>
            </div>
            <div t-if="state.open" class="ms-4 mt-1">
                <div t-foreach="props.transactions" t-as="move" t-key="move.id"
                     class="d-flex justify-content-between text-muted small">
                    <span t-esc="move.name"/>
                    <span t-esc="formatCurrency(move.amount)"/>
                </div>
            </div>
        </div>
    </t>

    <t t-name="pos_conventional_session_management.ClosingPopup">
        <Dialog contentClass="'close-pos-popup'" size="'lg'"
                title="state.sessionName ? 'Cerrando caja — ' + state.sessionName : 'Cerrando la caja registradora'">
            <div class="o_closing_popup_content">

                <!-- Banda de identificación de sesión -->
                <div class="alert alert-warning align-items-center justify-content-between mb-3 py-2 px-3 rounded">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa fa-lock fa-fw me-1"/>
                        <span class="fw-semibold">Cierre de sesión</span>
                    </div>
                    <span class="fw-bold fs-4" t-esc="state.sessionName || '...'"/>
                </div>
                <div t-if="!state.loading" class="p-3 bg-light rounded mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-4 fw-bold">Total Pedidos</span>
                        <span class="fs-4 fw-bolder" t-esc="formatCurrency(state.ordersDetails.amount)"/>
                    </div>
                    <div class="text-end text-muted small mt-1">
                        (<t t-esc="state.ordersDetails.quantity"/> pedidos)
                    </div>
                </div>
                <div t-if="state.loading" class="text-center py-5">
                    <i class="fa fa-spinner fa-spin fa-3x"/>
                    <p class="mt-3">Cargando datos de cierre...</p>
                </div>
                <div t-else="" class="payment-methods-overview">
                    <div t-if="state.cashDetails" class="w-100 mb-3">
                        <t t-set="cashDiff" t-value="getDifference(state.cashDetails.id)"/>
                        <t t-set="cashCounted" t-value="state.payments[state.cashDetails.id]?.counted || '0'"/>
                        <div class="d-flex align-items-center justify-content-between fs-3">
                            <span t-esc="state.cashDetails.name"/>
                            <span t-esc="formatCurrency(state.cashDetails.amount)"/>
                        </div>
                        <PaymentMethodBreakdown
                            title="'Entrada y salida de efectivo'"
                            total_amount="cashMoveData.total"
                            transactions="cashMoveData.moves"
                            currencyId="state.currencyId"
                            currencyName="state.currencyName"/>
                        <div class="d-flex align-items-center justify-content-between border-start ps-2"
                             t-att-class="{'text-danger fw-bold': cashDiff !== 0}">
                            <span>Diferencia</span>
                            <span t-esc="formatCurrency(cashDiff)"/>
                        </div>
                    </div>
                    <div class="w-100 mb-3" t-foreach="state.paymentMethods" t-as="pm" t-key="pm.id">
                        <t t-set="_showDiff" t-value="pm.type === 'bank' and pm.number !== 0"/>
                        <t t-set="pmDiff" t-value="_showDiff ? getDifference(pm.id) : 0"/>
                        <div class="d-flex align-items-center justify-content-between fs-3">
                            <span t-esc="pm.name"/>
                            <span t-esc="formatCurrency(pm.amount)"/>
                        </div>
                        <div class="d-flex align-items-center justify-content-between border-start ps-2"
                             t-att-class="{'text-danger fw-bold': pmDiff !== 0}">
                            <span>Diferencia</span>
                            <span t-esc="formatCurrency(pmDiff)"/>
                        </div>
                    </div>
                    <hr/>
                    <div t-if="state.cashDetails" class="mb-3">
                        <label class="form-label fw-bold">Recuento de efectivo</label>
                        <div class="input-group">
                            <input type="text"
                                   class="form-control cash-input text-end"
                                   t-att-value="state.payments[state.cashDetails.id]?.counted || '0'"
                                   t-on-input="(ev) => this.onCashInputChange(ev)"/>
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    t-on-click="pasteCashTotal"
                                    t-att-title="'Rellenar con el total cobrado: ' + formatCurrency(state.cashDetails.amount)">
                                <i class="fa fa-paste me-1"/>
                            </button>
                        </div>
                    </div>
                    <div class="w-100 mb-3" t-foreach="state.paymentMethods" t-as="pm" t-key="pm.id">
                        <t t-if="pm.type === 'bank' and pm.number !== 0">
                            <label class="form-label fw-bold"><t t-esc="pm.name"/> </label>
                            <input type="text"
                                   class="form-control w-100 text-end"
                                   t-att-value="state.payments[pm.id]?.counted || '0'"
                                   t-on-input="(ev) => this.onPMInputChange(pm.id, ev)"/>
                        </t>
                    </div>
                    <div class="closing-notes-container d-flex flex-column flex-grow-1 align-items-start mt-3">
                        <label class="form-label fw-bold">Nota de cierre</label>
                        <textarea class="closing-notes form-control"
                                  style="height: 80px"
                                  rows="3"
                                  placeholder="Añadir una nota de cierre..."
                                  t-model="state.notes"/>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <div class="w-100 d-flex flex-wrap justify-content-between gap-2">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-lg" t-on-click="confirm" t-att-disabled="state.loading">
                            Cerrar caja
                        </button>
                        <button class="btn btn-secondary btn-lg" t-on-click="cancel">
                            Descartar
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-secondary btn-lg" t-on-click="cashMove">
                            E/S de efectivo
                        </button>
                        <button class="btn btn-secondary btn-lg" t-on-click="printDailySales">
                            <i class="fa fa-download me-1"/>
                            Venta diaria
                        </button>
                    </div>
                </div>
            </t>
        </Dialog>
    </t>

    <t t-name="pos_conventional_session_management.ClosingPopupAction">
        <div class="o_closing_popup_action"/>
    </t>
</templates>

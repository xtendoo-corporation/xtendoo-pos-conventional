<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_conventional_session_management.CashMovePopup">
        <Dialog contentClass="'cash-move-popup'" size="'md'" title="'Entrada / Salida de efectivo'">
            <div class="cash-move-content p-3">
                <div class="input-amount d-flex mb-3 gap-2">
                    <div class="input-group">
                        <button t-on-click="() => this.onClickButton('in')"
                                t-attf-class="input-type btn btn-lg lh-lg flex-grow-1 #{state.type === 'in' ? 'btn-success' : 'btn-outline-secondary' }">
                            <i class="fa fa-arrow-down me-2"/>
                            Entrada
                        </button>
                        <button t-on-click="() => this.onClickButton('out')"
                                t-attf-class="input-type btn btn-lg lh-lg flex-grow-1 #{state.type === 'out' ? 'btn-danger' : 'btn-outline-secondary' }">
                            <i class="fa fa-arrow-up me-2"/>
                            Salida
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Importe</label>
                    <div class="input-group">
                        <span t-if="state.currencyPosition === 'before'" class="input-group-text">
                            <t t-esc="state.currencySymbol"/>
                        </span>
                        <input type="text"
                               class="form-control form-control-lg text-end cash-amount-input"
                               t-ref="amountInput"
                               t-att-value="state.amount"
                               t-on-input="(ev) => state.amount = ev.target.value"
                               placeholder="0,00"/>
                        <span t-if="state.currencyPosition === 'after'" class="input-group-text">
                            <t t-esc="state.currencySymbol"/>
                        </span>
                        <button t-if="state.cashSalesTotal > 0"
                                class="btn btn-outline-secondary"
                                type="button"
                                t-on-click="pasteCashSalesTotal"
                                t-att-title="'Rellenar con el total cobrado en efectivo: ' + state.cashSalesTotalFormatted">
                            <i class="fa fa-paste me-1"/>
                            <t t-esc="state.cashSalesTotalFormatted"/>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Motivo</label>
                    <textarea class="form-control cash-reason"
                              placeholder="Escribe el motivo del movimiento..."
                              rows="3"
                              t-model="state.reason"/>
                </div>
            </div>
            <t t-set-slot="footer">
                <div class="w-100 d-flex flex-wrap justify-content-between gap-2">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-lg"
                                t-on-click="confirm"
                                t-att-disabled="!isValidCashMove() or state.loading">
                            <i t-if="state.loading" class="fa fa-spinner fa-spin me-2"/>
                            Confirmar
                        </button>
                        <button class="btn btn-secondary btn-lg" t-on-click="props.close">
                            Cancelar
                        </button>
                    </div>
                </div>
            </t>
        </Dialog>
    </t>
    <t t-name="pos_conventional_session_management.CashMovePopupAction">
        <div class="o_cash_move_popup_action"></div>
    </t>
</templates>

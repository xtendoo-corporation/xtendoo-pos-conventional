<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_session_closing_wizard_form" model="ir.ui.view">
        <field name="name">pos.session.closing.wizard.form</field>
        <field name="model">pos.session.closing.wizard</field>
        <field name="arch" type="xml">
            <form string="Cerrando la caja registradora" class="o_pos_session_closing_wizard">
                <field name="state" invisible="1" />
                <field name="currency_id" invisible="1" />
                <field name="cash_control" invisible="1" />
                <field name="total_payments" invisible="1" />
                <field name="cash_in_out_total" invisible="1" />
                <field name="cash_register_balance_start" invisible="1" />
                <field name="cash_register_balance_end" invisible="1" />
                <field name="cash_register_difference" invisible="1" />
                <header>
                    <h4 class="modal-title">Cerrando la caja registradora</h4>
                </header>
                <sheet>
                    <div invisible="state != 'input'">
                        <div class="o_payment_method_section" invisible="not cash_control">
                            <group string="Resumen de efectivo">
                                <field name="cash_register_balance_start" widget="monetary" readonly="1"/>
                                <field name="total_payments" widget="monetary" readonly="1"/>
                                <field name="cash_in_out_total" widget="monetary" readonly="1" invisible="cash_in_out_total == 0"/>
                                <field name="cash_register_balance_end" widget="monetary" readonly="1"/>
                                <field name="cash_register_balance_end_real" widget="monetary" string="Efectivo contado"/>
                                <field name="cash_register_difference" widget="monetary" readonly="1" decoration-danger="cash_register_difference &lt; 0" decoration-success="cash_register_difference &gt; 0"/>
                            </group>
                        </div>
                        <group string="Métodos de pago" invisible="not payment_method_line_ids">
                            <field name="payment_method_line_ids" nolabel="1">
                                <list editable="bottom" create="0" delete="0" decoration-danger="difference &lt; 0" decoration-success="difference &gt; 0">
                                    <field name="payment_method_id" string="Método de pago" readonly="1"/>
                                    <field name="amount_expected" widget="monetary" string="Esperado" readonly="1"/>
                                    <field name="amount_counted" widget="monetary" string="Contado"/>
                                    <field name="difference" widget="monetary" string="Diferencia" readonly="1"/>
                                    <field name="is_cash" column_invisible="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </group>
                        <div class="mb-3">
                            <label for="closing_note" class="o_form_label">Nota de cierre</label>
                            <field name="closing_note" placeholder="Razón de cierre (opcional)..."/>
                        </div>
                    </div>
                    <div invisible="state != 'confirmation'" class="o_pos_closing_confirmation">
                        <h4>Diferencia de pago</h4>
                        <p>
                            El efectivo contado no coincide con la cantidad esperada.<br/>
                            ¿Deseas registrar esta diferencia en las cuentas?
                        </p>
                    </div>
                </sheet>
                <footer>
                    <button name="action_close_session" string="Cerrar caja" type="object" class="btn-primary" invisible="state != 'input'" data-hotkey="q"/>
                    <button name="action_close_session" string="Continuar de todos modos" type="object" class="btn btn-primary" invisible="state != 'confirmation'" data-hotkey="q"/>
                    <button string="Cancelar" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

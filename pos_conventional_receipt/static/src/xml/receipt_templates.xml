<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_conventional_receipt.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="replace">
            <div style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 11px; text-align: left; line-height: 1.4; margin-bottom: 10px;">
                <t t-if="props.data.company.name">
                    <div style="font-weight: bold; font-size: 13px; text-transform: uppercase;"><t t-esc="props.data.company.name" /></div>
                </t>
                <t t-if="props.data.company.street">
                    <div><t t-esc="props.data.company.street" /></div>
                </t>
                <t t-if="props.data.company.zip || props.data.company.city">
                    <div><t t-esc="props.data.company.zip" /> <t t-esc="props.data.company.city" /></div>
                </t>
                <t t-if="props.data.company.vat">
                    <div>NIF: <t t-esc="props.data.company.vat" /></div>
                </t>
                
                <div style="border-top: 1px dashed black; margin: 6px 0;"/>

                <div style="text-transform: uppercase;">
                    <span style="font-weight: bold;">
                        <t t-if="props.data.headerData.ticket_type == 'out_refund'">FACTURA SIMPLIFICADA RECTIFICATIVA:</t>
                        <t t-else="">FACTURA SIMPLIFICADA:</t>
                    </span>
                    <t t-esc="props.data.name" />
                </div>
                <div><span style="font-weight: bold;">FECHA:</span> <t t-esc="props.data.date" /></div>

                <t t-set="partner" t-value="props.order.get_partner()"/>
                <t t-if="partner">
                    <div style="margin-top: 5px;">
                        <div><span style="font-weight: bold;">CLIENTE:</span> <t t-esc="partner.name" /></div>
                        <div t-if="partner.street"><t t-esc="partner.street" /></div>
                        <div t-if="partner.zip"><t t-esc="partner.zip" /> <t t-esc="partner.city" /></div>
                        <div t-if="partner.vat">NIF: <t t-esc="partner.vat" /></div>
                    </div>
                </t>
            </div>
        </xpath>
    </t>

    <t t-name="pos_conventional_receipt.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="replace">
            <!-- Quitamos la fecha de abajo porque ya la pusimos arriba -->
        </xpath>

        <!-- Desglose de IVA personalizado -->
        <xpath expr="//div[hasclass('pos-receipt-taxes')]" position="replace">
            <div t-if="props.order.prices.taxDetails and props.order.prices.taxDetails.has_tax_groups" 
                 class="pos-receipt-taxes pt-2" 
                 style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 11px;">
                <div class="d-flex" style="border-bottom: 1px dashed black; font-weight: bold; margin-bottom: 2px;">
                    <span style="flex: 1; text-align: left;">BASE</span>
                    <span style="flex: 1; text-align: center;">IMPUESTO</span>
                    <span style="flex: 1; text-align: right;">CUOTA</span>
                </div>
                <t t-foreach="props.order.prices.taxDetails.subtotals" t-as="subtotal" t-key="subtotal.name">
                    <div t-foreach="subtotal.tax_groups" t-as="tax_group" t-key="tax_group.id" class="d-flex">
                        <span style="flex: 1; text-align: left;"><t t-esc="formatCurrency(tax_group.base_amount_currency)"/></span>
                        <span style="flex: 1; text-align: center;"><t t-esc="tax_group.group_name"/></span>
                        <span style="flex: 1; text-align: right;"><t t-esc="formatCurrency(tax_group.tax_amount_currency)"/></span>
                    </div>
                </t>
                <div style="border-top: 1px dashed black; margin-top: 2px;"/>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('after-footer')]" position="before">
            <div style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 11px; text-align: center; margin-top: 5px;">
                <div style="margin-bottom: 2px;">Gracias por su visita</div>
                <div>Atendido por: <t t-esc="props.order.getCashierName()"/></div>
            </div>
        </xpath>
    </t>
</templates>
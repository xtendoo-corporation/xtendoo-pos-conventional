<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_conventional_receipt.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">

        <xpath expr="//div[hasclass('pos-receipt-customer') and contains(@t-if, 'order.partner_id')]"
               position="replace">
        </xpath>
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="replace">
            <t t-set="data" t-value="props.data || (props.order &amp;&amp; (props.order.raw || props.order))"/>
            <t t-set="company"
               t-value="props.order.company || data.company || (env &amp;&amp; env.pos &amp;&amp; env.pos.company_printable) || (env &amp;&amp; env.pos &amp;&amp; env.pos.company) || (props.order &amp;&amp; props.order.pos &amp;&amp; props.order.pos.company_printable) || {}"/>
            <t t-if="data">
                <div class="custom-header"
                     style="font-family: 'Lucida Console', 'DejaVu Sans Mono', 'Liberation Mono', monospace; font-weight: normal; text-align: center; font-size: 13px; line-height: 1.2; padding: 0; margin: 0;">

                    <!-- Datos de la empresa -->
                    <div style="margin-top: 5px; margin-bottom: 3px; font-weight: bold;">
                        <t t-esc="company.name || ''"/>
                    </div>
                    <div style="font-size: 10px;">
                        <t t-if="company.street">
                            <t t-esc="company.street"/>
                            <br/>
                        </t>
                        <t t-if="company.zip || company.city">
                            <t t-esc="company.street2 || ''"/>
                            <t t-if="company.street2"><br/></t>
                            <t t-esc="company.zip"/>
                            <t t-if="company.city">
                                <t t-esc="' ' + company.city"/>
                            </t>
                            <br/>
                        </t>
                        <t t-if="company.phone">
                            Tlf <t t-esc="company.phone"/>
                            <br/>
                        </t>
                        <t t-if="company.vat">
                            <t t-esc="company.vat"/>
                        </t>
                    </div>

                    <!-- Línea separadora -->
                    <div style="border-top: 1px dashed black; margin: 4px 0;"/>

                    <!-- Información de la factura -->
                    <div style="font-size: 10px; text-align: left; padding: 0;">
                        <div style="margin-bottom: 2px;">
                            <strong>FACTURA SIMPLIFICADA:</strong> <t t-esc="props.order.name || ''"/>
                        </div>
                        <div style="margin-bottom: 2px;">
                            <strong>FECHA:</strong>
                            <t t-if="props.order &amp;&amp; props.order.date_order" t-out="props.order.formatDateOrTime('date_order')"/>
                        </div>

                        <!-- Datos del cliente (si existe) -->
                        <t t-set="partner" t-value="(props.data &amp;&amp; props.data.partner) || (props.order &amp;&amp; props.order.get_partner ? props.order.get_partner() : (props.order ? props.order.partner_id || props.order.partner : null))"/>
                        <t t-if="partner">
                            <div style="margin-bottom: 2px;">
                                <strong>CLIENTE:</strong> <t t-esc="partner.name || partner.display_name || ''"/>
                            </div>
                            <t t-if="partner.vat">
                                <div style="margin-bottom: 2px;">
                                    <strong>NIF/CIF:</strong> <t t-esc="partner.vat"/>
                                </div>
                            </t>
                            <t t-if="partner.street || partner.city">
                                <div style="margin-bottom: 2px;">
                                    <t t-esc="partner.street || ''"/>
                                    <t t-if="partner.street and partner.city"> - </t>
                                    <t t-esc="partner.city || ''"/>
                                    <t t-if="partner.zip"> (<t t-esc="partner.zip"/>)</t>
                                </div>
                            </t>
                        </t>

                    </div>

                    <!-- Línea separadora -->
                    <div style="border-top: 1px dashed black; margin: 4px 0;"/>
                </div>
            </t>
        </xpath>
        <xpath expr="//span[hasclass('pos-receipt-vat')]" position="replace"/>

        <!-- Remove core order-date (below the logo) so only our custom date remains -->
        <xpath expr="//div[@id='order-date']" position="replace"/>

    </t>

    <t t-name="pos_conventional_receipt.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">


        <xpath expr="//div[hasclass('pos-receipt', 'p-2')]" position="attributes">
             <attribute name="class">pos-receipt</attribute>
            <attribute name="style">font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-weight: normal; letter-spacing: 0.5px; text-align: center; font-size: 12px;</attribute>
         </xpath>

        <xpath expr="//OrderDisplay" position="replace">
            <div class="pos-receipt-container"
                 style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 10px; text-align: left; padding: 0; margin: 0;">
                <!-- Encabezado de tabla -->
                <div style="display: flex; justify-content: space-between; margin-bottom: 3px; font-weight: bold;">
                    <span style="flex: 3;">Nombre</span>
                    <span style="flex: 0.5; text-align: center;">UD</span>
                    <span style="flex: 1; text-align: right;">TOTAL</span>
                </div>

                <!-- Líneas de productos -->
                <t t-foreach="props.order.orderlines || props.order.lines || []" t-as="line" t-key="line.id">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1px; line-height: 1.2;">
                        <span style="flex: 3; word-break: break-word; font-weight: normal;">
                            <t t-esc="line.custom_line_name || line.name || line.product_id.display_name"/>
                        </span>
                        <span style="flex: 0.5; text-align: center; font-weight: normal;">
                            <t t-esc="line.qty"/>
                        </span>
                        <span style="flex: 1; text-align: right; font-weight: normal;">
                      <t t-esc="(formatCurrency(line.price_subtotal_incl || 0) || '').replaceAll('\u00A0','').replaceAll(' ','')"/>
                        </span>
                    </div>
                    <!-- Líneas adicionales debajo del producto -->
                    <div t-if="line.discount &amp;&amp; line.discount &gt; 0"
                         style="font-size: 9px; color: #666; margin-left: 3px; margin-bottom: 1px;">
                        Dto. <t t-esc="line.discount"/>%
                    </div>
                    <div t-if="line.customerNote"
                         style="font-size: 9px; font-style: italic; margin-left: 3px; margin-bottom: 1px;">
                        [<t t-esc="line.customerNote"/>]
                    </div>
                </t>

                <!-- Línea separadora -->
                <div style="border-top: 1px dashed black; margin: 4px 0;"/>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('before-footer')]" position="before">
            <t t-if="!props.basic_receipt">
                <div
                    style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 11px; text-align: center; padding: 0; margin: 0;">

                    <!-- TOTAL grande -->
                    <div
                        style="display: flex; justify-content: flex-end; align-items: center; font-size: 14px; font-weight: bold; margin: 5px 0;">
                        <span style="margin-right: 10px;">TOTAL</span>
                        <span><t t-esc="(formatCurrency(props.order.amount_total || 0) || '').replaceAll('\u00A0','').replaceAll(' ','')"/></span>
                    </div>

                    <!-- Método de pago -->
                    <div style="font-size: 10px; text-align: center; margin: 4px 0;">
                        <t t-if="paymentLines &amp;&amp; paymentLines.length &gt; 0">
                            <t t-foreach="paymentLines" t-as="line" t-key="line_index">
                                Forma de pago: <t t-esc="line.payment_method_id.name.toLowerCase()"/>
                            </t>
                        </t>
                    </div>

                    <!-- Línea separadora -->
                    <div style="border-top: 1px dashed black; margin: 4px 0;"/>

                    <!-- Tabla de IVA -->
                    <t t-set="taxTotals" t-value="order.prices.taxDetails"/>
                    <t t-if="taxTotals &amp;&amp; taxTotals.has_tax_groups">
                        <div
                            style="display: flex; justify-content: space-between; font-size: 10px; text-align: right; margin-bottom: 2px;">
                            <span style="flex: 1;">Impuesto</span>
                            <span style="flex: 1;">Base</span>
                            <span style="flex: 1;">Cuota</span>
                        </div>
                        <t t-foreach="taxTotals.subtotals" t-as="subtotal" t-key="subtotal.name">
                            <t t-foreach="subtotal.tax_groups" t-as="tax_group" t-key="tax_group.id">
                                <div
                                    style="display: flex; justify-content: space-between; font-size: 10px; text-align: right; margin-bottom: 1px;">
                                    <span style="flex: 1;">
                                        <t t-esc="tax_group.tax_group_name || tax_group.group_name"/>
                                    </span>
                                    <span style="flex: 1;">
                                        <t t-esc="(formatCurrency(tax_group.base_amount_currency || tax_group.base_amount || 0) || '').replaceAll('\u00A0','').replaceAll(' ','')"/>
                                    </span>
                                    <span style="flex: 1;">
                                        <t t-esc="(formatCurrency(tax_group.tax_amount_currency || tax_group.tax_amount || 0) || '').replaceAll('\u00A0','').replaceAll(' ','')"/>
                                    </span>
                                </div>
                            </t>
                        </t>
                    </t>

                    <!-- Línea separadora -->
                    <div style="border-top: 1px dashed black; margin: 4px 0;"/>

                </div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt-taxes', 'pt-3')]" position="replace"/>
        <xpath expr="//div[hasclass('pos-receipt-amount', 'receipt-total')]" position="replace"/>
        <xpath expr="//div[hasclass('receipt-rounding')]" position="replace"/>
        <xpath expr="//div[hasclass('receipt-to-pay')]" position="replace"/>
        <xpath expr="//div[hasclass('paymentlines', 'text-start', 'pt-1')]" position="replace"/>
        <xpath expr="//div[hasclass('pos-receipt-amount', 'receipt-change')]" position="replace"/>
        <xpath expr="//div/span[hasclass('label-discount')]/../.." position="replace"/>
        <xpath expr="//div[hasclass('gap-2','d-flex','flex-row','pt-3')]" position="replace"/>
        <xpath expr="//div[hasclass('pos-receipt-center-align')]" position="replace"/>
        <xpath expr="//div[hasclass('pos-receipt-order-data', 'd-flex', 'gap-2', 'pt-3')]" position="replace"/>
        <xpath expr="//div[hasclass('d-flex', 'gap-2', 'pt-3')]" position="replace"/>
        <xpath expr="//div[contains(., 'Powered by') and hasclass('pos-receipt-order-data')]" position="replace"/>

        <xpath expr="//div[hasclass('after-footer')]" position="before">
            <!-- Footer personalizado -->
            <div style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 10px; text-align: center; margin-top: 5px;">
                <div style="margin-bottom: 3px;">
                    Gracias por su visita
                </div>

                <!-- Línea separadora final -->
                <div style="border-top: 1px dashed black; margin: 4px 0;"/>
            </div>

            <div style="font-family: 'Lucida Console', 'DejaVu Sans Mono', monospace; font-size: 10px; text-align: center; margin-top: 5px;">
                <div t-if="props.order.getCashierName">
                    Atendido por: <t t-esc="props.order.getCashierName()"/>
                </div>
            </div>
        </xpath>

     </t>
 </templates>
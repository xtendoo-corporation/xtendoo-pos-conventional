<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_pin" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.pin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_interface_section']" position="inside">
                <setting help="Pide el PIN del usuario después de cada venta (solo modo no táctil).">
                    <field name="pos_force_employee_login_after_order"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_session_pin_wizard_form" model="ir.ui.view">
        <field name="name">pos.session.pin.wizard.form</field>
        <field name="model">pos.session.pin.wizard</field>
        <field name="arch" type="xml">
            <form string="Validar PIN de apertura POS">
                <sheet>
                    <div class="alert alert-info mb-3" role="alert">
                        <p class="mb-0">
                            <strong>Validación de PIN</strong><br/>
                            Por favor, ingrese su PIN para continuar.
                        </p>
                    </div>
                    <group>
                        <field name="session_id" invisible="1"/>
                        <field name="user_id" invisible="1"/>
                        <label for="pos_pin" string="PIN"/>
                        <field name="pos_pin" password="True" required="1" placeholder="Ingrese su PIN (ej: 1234)" nolabel="1"/>
                    </group>
                </sheet>
                    <footer>
                        <button name="action_validate_pin" string="Validar PIN" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel" invisible="context.get('no_cancel')"/>
                    </footer>
            </form>
        </field>
    </record>
</odoo>

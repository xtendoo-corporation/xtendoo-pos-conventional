<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_session_pin_wizard_form" model="ir.ui.view">
        <field name="name">pos.session.pin.wizard.form</field>
        <field name="model">pos.session.pin.wizard</field>
        <field name="arch" type="xml">
            <form string="Validar PIN">
                <sheet>
                    <group>
                        <field name="session_id" invisible="1"/>
                        <field name="user_id" readonly="1"/>
                        <field name="pos_pin" password="True" required="1" 
                               placeholder="Ingrese su PIN de 4 dígitos"
                               on_change="1"/>
                    </group>
                    <footer>
                        <button name="action_validate_pin" string="Validar" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

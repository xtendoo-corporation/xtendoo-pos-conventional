<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="paperformat_receipt_80mm" model="report.paperformat">
        <field name="name">Ticket 80mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">297</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_factura_simplificada_80mm_pdf" model="ir.actions.report">
        <field name="name">Factura Simplificada 80mm (HTML)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">pos_conventional_receipt_custom.report_factura_simplificada_80mm</field>
        <field name="report_file">pos_conventional_receipt_custom.report_factura_simplificada_80mm</field>
        <field name="print_report_name">'Ticket_%s' % object.name.replace('/', '_')</field>
        <field name="paperformat_id" ref="pos_conventional_receipt_custom.paperformat_receipt_80mm"/>
    </record>

    <record id="email_template_pos_receipt" model="mail.template">
        <field name="name">POS: Envío de Ticket</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="subject">Su ticket de compra - {{ object.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #555; padding: 20px;">
                <p>Estimado/a <t t-out="object.partner_id.name or 'Cliente'">Cliente</t>,</p>
                <p>Adjunto encontrará el ticket correspondiente a su compra realizada en <strong><t t-out="object.company_id.name">Empresa</t></strong>.</p>
                <p>
                    <strong>Referencia:</strong> <t t-out="object.name">INV/2024/0001</t><br/>
                    <strong>Fecha:</strong> <t t-out="object.invoice_date">01/01/2024</t><br/>
                    <strong>Total:</strong> <t t-out="object.amount_total">0.00</t> <t t-out="object.currency_id.symbol">€</t>
                </p>
                <p>Gracias por su confianza.</p>
                <p>
                    Atentamente,<br/>
                    <strong><t t-out="object.company_id.name">Empresa</t></strong>
                </p>
            </div>
        </field>
        <field name="report_template_ids" eval="[(4, ref('pos_conventional_receipt_custom.action_factura_simplificada_80mm_pdf'))]"/>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
    </data>
</odoo>


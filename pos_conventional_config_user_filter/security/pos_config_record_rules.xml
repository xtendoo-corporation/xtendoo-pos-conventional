<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Grupo para ver todos los POS -->
    <record id="group_pos_config_all" model="res.groups">
        <field name="name">Ver todos los POS</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <!-- Regla general: solo ver los POS permitidos o basados en la compañía -->
    <record id="pos_config_rule_allowed" model="ir.rule">
        <field name="name">POS: Solo ver los permitidos</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">['|', ('id', 'in', user.allowed_pos_config_ids.ids), ('company_id', 'in', user.company_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Regla para el grupo especial: ver todos los POS -->
    <record id="pos_config_rule_all" model="ir.rule">
        <field name="name">POS: Ver todos los POS (grupo especial)</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('pos_conventional_config_user_filter.group_pos_config_all'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>

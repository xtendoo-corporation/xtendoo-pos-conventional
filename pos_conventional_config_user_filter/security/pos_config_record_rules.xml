<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Regla: los usuarios solo ven las cajas POS permitidas para su usuario
         o las cajas de sus compañías -->
    <record id="pos_config_rule_allowed" model="ir.rule">
        <field name="name">POS: Solo ver los POS permitidos por usuario</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">['|', ('id', 'in', user.allowed_pos_config_ids.ids), ('company_id', 'in', user.company_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Los managers de POS pueden ver todas las cajas sin restricción -->
    <record id="pos_config_rule_manager_all" model="ir.rule">
        <field name="name">POS: Managers ven todos los POS</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('point_of_sale.group_pos_manager'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>

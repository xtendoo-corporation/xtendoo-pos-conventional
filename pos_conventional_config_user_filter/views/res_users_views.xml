<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_pos_config_filter" model="ir.ui.view">
        <field name="name">res.users.form.inherit.pos.config.filter</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_ids']" position="after">
                <field name="allowed_pos_config_ids"
                       widget="many2many_tags"
                       options="{'no_create': True}"
                       domain="[('company_id', 'in', company_ids)]"
                       groups="point_of_sale.group_pos_manager"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_cash_calculator_wizard_form" model="ir.ui.view">
        <field name="name">pos.cash.calculator.wizard.form</field>
        <field name="model">pos.cash.calculator.wizard</field>
        <field name="arch" type="xml">
            <form string="Calculadora de Monedas y Billetes">
                <sheet>
                    <div class="row">
                        <div class="col-8">
                            <group string="Billetes">
                                <div class="o_group_col_6">
                                    <label for="qty_200" string="200€"/>
                                    <div class="o_row">
                                        <button name="decrement_200" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_200"/>
                                        <button name="increment_200" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_100" string="100€"/>
                                    <div class="o_row">
                                        <button name="decrement_100" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_100"/>
                                        <button name="increment_100" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_50" string="50€"/>
                                    <div class="o_row">
                                        <button name="decrement_50" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_50"/>
                                        <button name="increment_50" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                </div>
                                <div class="o_group_col_6">
                                    <label for="qty_20" string="20€"/>
                                    <div class="o_row">
                                        <button name="decrement_20" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_20"/>
                                        <button name="increment_20" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_10" string="10€"/>
                                    <div class="o_row">
                                        <button name="decrement_10" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_10"/>
                                        <button name="increment_10" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_5" string="5€"/>
                                    <div class="o_row">
                                        <button name="decrement_5" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_5"/>
                                        <button name="increment_5" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                </div>
                            </group>
                            <group string="Monedas">
                                <div class="o_group_col_6">
                                    <label for="qty_2" string="2€"/>
                                    <div class="o_row">
                                        <button name="decrement_2" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_2"/>
                                        <button name="increment_2" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_1" string="1€"/>
                                    <div class="o_row">
                                        <button name="decrement_1" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_1"/>
                                        <button name="increment_1" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_050" string="0,50€"/>
                                    <div class="o_row">
                                        <button name="decrement_050" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_050"/>
                                        <button name="increment_050" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                </div>
                                <div class="o_group_col_6">
                                    <label for="qty_020" string="0,20€"/>
                                    <div class="o_row">
                                        <button name="decrement_020" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_020"/>
                                        <button name="increment_020" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_010" string="0,10€"/>
                                    <div class="o_row">
                                        <button name="decrement_010" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_010"/>
                                        <button name="increment_010" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                    <label for="qty_005" string="0,05€"/>
                                    <div class="o_row">
                                        <button name="decrement_005" string="-" type="object" class="btn-secondary"/>
                                        <field name="qty_005"/>
                                        <button name="increment_005" string="+" type="object" class="btn-secondary"/>
                                    </div>
                                </div>
                            </group>
                        </div>
                        <div class="col-4 bg-light p-3">
                            <h2 class="text-center mt-4">Total</h2>
                            <div class="text-center display-4 text-primary">
                                <field name="total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>
                            <field name="currency_id" invisible="1"/>
                            <field name="parent_model" invisible="1"/>
                            <field name="parent_res_id" invisible="1"/>
                        </div>
                    </div>
                    <footer>
                        <button name="action_confirm" string="Confirmar" type="object" class="btn-primary"/>
                        <button name="action_cancel" string="Cancelar" type="object" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_cash_calculator_wizard" model="ir.actions.act_window">
        <field name="name">Calculadora de Efectivo</field>
        <field name="res_model">pos.cash.calculator.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_pos_form_inherit_pos_conventional_core" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.pos.conventional.core</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="payment_method_ribbon" invisible="1"/>
            </xpath>
            <xpath expr="//sheet" position="before">
                <div class="oe_link_ribbon bg-success"
                     invisible="not payment_method_ribbon or state not in ('paid', 'done')"
                     style="z-index: 1000;">
                    <field name="payment_method_ribbon"/>
                </div>
            </xpath>
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="amount_untaxed" widget="monetary" options="{'currency_field': 'currency_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>

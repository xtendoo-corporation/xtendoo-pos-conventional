<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_inherit_pos_conventional_core" model="ir.ui.view">
        <field name="name">pos.config.view.form.inherit.pos.conventional.core</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="pos_non_touch" />
                <field name="default_partner_id" widget="res_partner_many2one" 
                       context="{'show_address': 1}" options='{"always_reload": True}' 
                       placeholder="Cliente por defecto"
                       invisible="not pos_non_touch" />
            </xpath>
        </field>
    </record>
</odoo>

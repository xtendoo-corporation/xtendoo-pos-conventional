<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_picking" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.picking</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_interface_section']" position="inside">
                <setting help="Permite la creación automática de albaranes de venta desde el POS (solo modo no táctil).">
                    <field name="pos_enable_albaran"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
